# secrets
.env

# python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# local scratch / throwaway prototype (not part of the build)
prototype/

# fixtures hold real student theses (PII) + a school's spec — repo is PUBLIC, keep local only
fixtures/*
!fixtures/README.md

# extracted institutional assets (校名标准字 from spec docs) — don't republish; regenerate locally
templates/assets/*
!templates/assets/README.md

# user-compiled templates (from 上传新规范, derived from user docs) — persist LOCALLY, don't publish/delete
templates/custom-*.yaml

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# runtime job artifacts
app/_jobs/
*.converted.docx
_*.tmp
